      <trans-unit id="service.fiscalidade.name" datatype="html">
        <source>Fiscalidade e Contabilidade</source>
        <target>Taxation and Accounting</target>
      </trans-unit>
      <trans-unit id="service.fiscalidade.desc" datatype="html">
        <source>Gestão fiscal e contabilística completa para empresas e particulares. Declarações fiscais, IVA, IRC/IRS empresarial e aconselhamento tributário.</source>
        <target>Complete tax and accounting management for businesses and individuals. Tax returns, VAT, corporate tax and tax advisory.</target>
      </trans-unit>
      <trans-unit id="service.juridica.name" datatype="html">
        <source>Serviços Jurídicos</source>
        <target>Legal Services</target>
      </trans-unit>
      <trans-unit id="service.juridica.desc" datatype="html">
        <source>Assessoria jurídica especializada para empresas e particulares. Contratos, direito comercial, laboral e apoio em litígios.</source>
        <target>Specialised legal advice for businesses and individuals. Contracts, commercial and labour law, and litigation support.</target>
      </trans-unit>
      <trans-unit id="service.empresas.name" datatype="html">
        <source>Consultadoria Empresarial</source>
        <target>Business Consultancy</target>
      </trans-unit>
      <trans-unit id="service.empresas.desc" datatype="html">
        <source>Estratégia, planeamento e gestão empresarial. Reestruturação organizacional, planos de negócio e melhoria de processos.</source>
        <target>Strategy, planning, and business management. Organisational restructuring, business plans, and process improvement.</target>
      </trans-unit>
      <trans-unit id="service.rendas.name" datatype="html">
        <source>Gestão de Rendas</source>
        <target>Rental Management</target>
      </trans-unit>
      <trans-unit id="service.rendas.desc" datatype="html">
        <source>Administração e gestão de imóveis arrendados. Contratos de arrendamento, actualização de rendas e acompanhamento legal.</source>
        <target>Administration and management of rented properties. Lease agreements, rent updates, and legal support.</target>
      </trans-unit>
      <trans-unit id="service.credito.name" datatype="html">
        <source>Intermediação de Crédito</source>
        <target>Credit Intermediation</target>
      </trans-unit>
      <trans-unit id="service.credito.desc" datatype="html">
        <source>Intermediação e aconselhamento em crédito habitação, crédito pessoal e financiamento empresarial. Encontramos as melhores condições para o seu perfil.</source>
        <target>Credit brokerage and advisory for home loans, personal credit, and business financing. We find the best conditions for your profile.</target>
      </trans-unit>
