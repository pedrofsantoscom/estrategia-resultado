Options -Indexes

# Remove PHP version from responses
Header unset X-Powered-By
Header always unset X-Powered-By

RewriteEngine On

# Block access to sensitive directories
RewriteRule ^(tmp|vendor|src)(/|$) - [F,L]

# Block access to sensitive files
<FilesMatch "^(config\.php|composer\.json|composer\.lock)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Only allow known API routes (extensionless)
RewriteCond %{REQUEST_URI} !^/api/(contact|contact-request)$
RewriteRule ^api/.*$ - [R=404,L]

# Rewrite extensionless API routes to .php files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/(.*)$ api/$1.php [L,QSA]
